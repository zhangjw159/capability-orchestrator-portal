{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "trailingCommas": "es5"
    },
    "globals": ["React", "JSX"]
  },
  "linter": {
    "rules": {
      "recommended": true,
      "correctness": { "noUnusedVariables": "warn" },
      "style": { "useBlockStatements": "off", "useNodejsImportProtocol": "off" },
      "suspicious": {
        "noExplicitAny": "off",
        "noDoubleEquals": "off",
        "noArrayIndexKey": "warn",
        "noDebugger": "warn",
        "noEmptyBlockStatements": "warn"
      },
      "a11y": {
        "useKeyWithClickEvents": "off",
        "useKeyWithMouseEvents": "off"
      }
    }
  }
}
